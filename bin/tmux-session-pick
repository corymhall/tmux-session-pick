#!/usr/bin/env bash
set -euo pipefail

CURRENT_SOCKET=""
CURRENT_SESSION=""

notify_user() {
  local message="$1"
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message "$message"
    return
  fi
  printf '%s\n' "$message" >&2
}

trim_whitespace() {
  sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

normalize_picker_mode() {
  case "${1:-}" in
    sessions|crews|rigs|all)
      printf '%s\n' "$1"
      ;;
    *)
      printf 'sessions\n'
      ;;
  esac
}

ensure_tmux_option_server() {
  tmux start-server >/dev/null 2>&1 || true
}

tmux_option_or_fallback() {
  local option_value
  ensure_tmux_option_server
  option_value="$(tmux show-option -gqv "$1" 2>/dev/null || true)"
  if [[ -z "$option_value" ]]; then
    option_value="$2"
  fi
  echo "$option_value"
}

current_picker_mode() {
  normalize_picker_mode "$(tmux_option_or_fallback '@tmux-session-pick-mode' 'sessions')"
}

set_picker_mode() {
  local mode
  mode="$(normalize_picker_mode "$1")"
  ensure_tmux_option_server
  tmux set-option -gq '@tmux-session-pick-mode' "$mode" 2>/dev/null || true
}

cycle_picker_mode() {
  case "$(current_picker_mode)" in
    sessions)
      set_picker_mode crews
      ;;
    crews)
      set_picker_mode rigs
      ;;
    rigs)
      set_picker_mode all
      ;;
    *)
      set_picker_mode sessions
      ;;
  esac
}

socket_from_tmux_env() {
  local tmux_env socket_path socket_name
  tmux_env="${TMUX:-}"
  if [[ -z "$tmux_env" ]]; then
    return 1
  fi
  socket_path="${tmux_env%%,*}"
  socket_name="${socket_path##*/}"
  [[ -n "$socket_name" ]] || return 1
  printf '%s\n' "$socket_name"
}

collect_sockets() {
  local current
  current="$(socket_from_tmux_env || true)"
  printf '%s\n' "$current" default gt | awk 'NF' | awk '!seen[$0]++'
}

get_sorted_sessions_for_socket() {
  local socket="$1" last_session sessions
  last_session="$(tmux -L "$socket" display-message -p '#{client_last_session}' 2>/dev/null || true)"
  sessions="$(tmux -L "$socket" list-sessions -F '#{session_name}' 2>/dev/null || true)"
  if [[ -z "$sessions" ]]; then
    return 0
  fi
  if [[ -n "$last_session" ]]; then
    echo "$sessions" | grep -v "^$last_session$" || true
    echo "$last_session"
  else
    echo "$sessions"
  fi | awk 'NF' | awk '!seen[$0]++'
}

build_tmux_rows() {
  local socket session attached
  while IFS= read -r socket; do
    while IFS= read -r session; do
      [[ -n "$session" ]] || continue
      attached="$(tmux -L "$socket" list-sessions -F '#{session_name}\t#{?session_attached,yes,no}' 2>/dev/null | awk -F'\t' -v s="$session" '$1==s{print $2; exit}')"
      [[ -n "$attached" ]] || attached="no"
      printf 'session\t\t%s\t%s\t%s\t%s\t%s\t[%s] %s\n' \
        "$session" "$attached" "$socket" "$session" "$attached" "$socket" "$session"
    done < <(get_sorted_sessions_for_socket "$socket")
  done < <(collect_sockets)
}

list_rigs_tsv() {
  command -v gt >/dev/null 2>&1 || return 0
  # Expect one key per line from `gt rig list --json`; keep this parser small
  # and dependency-free, but documented so shape changes are easier to spot.
  gt rig list --json 2>/dev/null | awk '
    function flush() {
      if (name != "") {
        printf "%s\t%s\t%s\t%s\n", name, status, crew, polecats
      }
      name = ""
      status = ""
      crew = ""
      polecats = ""
    }
    /"name":/ {
      line = $0
      sub(/.*"name":[[:space:]]*"/, "", line)
      sub(/".*/, "", line)
      name = line
    }
    /"status":/ {
      line = $0
      sub(/.*"status":[[:space:]]*"/, "", line)
      sub(/".*/, "", line)
      status = line
    }
    /"crew":/ {
      line = $0
      sub(/.*"crew":[[:space:]]*/, "", line)
      sub(/,.*/, "", line)
      crew = line
    }
    /"polecats":/ {
      line = $0
      sub(/.*"polecats":[[:space:]]*/, "", line)
      sub(/,.*/, "", line)
      polecats = line
    }
    /^[[:space:]]*}/ {
      flush()
    }
  '
}

list_crews_tsv() {
  local rig="$1"
  command -v gt >/dev/null 2>&1 || return 0
  # Expect one key per line from `gt crew list --rig <rig> --json`.
  gt crew list --rig "$rig" --json 2>/dev/null | awk -v rig="$rig" '
    function flush() {
      if (name != "") {
        branch_value = branch
        if (branch_value == "") {
          branch_value = "-"
        }
        live = (has_session == "true" ? "online" : "offline")
        git = (git_clean == "true" ? "clean" : "dirty")
        printf "%s\t%s\t%s\t%s\t%s\n", rig, name, branch_value, live, git
      }
      name = ""
      branch = ""
      has_session = ""
      git_clean = ""
    }
    /"name":/ {
      line = $0
      sub(/.*"name":[[:space:]]*"/, "", line)
      sub(/".*/, "", line)
      name = line
    }
    /"branch":/ {
      line = $0
      sub(/.*"branch":[[:space:]]*"/, "", line)
      sub(/".*/, "", line)
      branch = line
    }
    /"has_session":/ {
      line = $0
      sub(/.*"has_session":[[:space:]]*/, "", line)
      sub(/,.*/, "", line)
      gsub(/[[:space:]]+/, "", line)
      has_session = line
    }
    /"git_clean":/ {
      line = $0
      sub(/.*"git_clean":[[:space:]]*/, "", line)
      sub(/,.*/, "", line)
      gsub(/[[:space:]]+/, "", line)
      git_clean = line
    }
    /^[[:space:]]*}/ {
      flush()
    }
  '
}

build_gastown_rows() {
  local mode="$1"
  local rig status crew_count polecats crew_name branch live git_state sling_state
  while IFS=$'\t' read -r rig status crew_count polecats; do
    [[ -n "$rig" ]] || continue
    sling_state="ready"
    if [[ "$status" == "docked" ]]; then
      sling_state="blocked"
    fi
    if [[ "$mode" == "rigs" || "$mode" == "all" ]]; then
      printf 'rig\t%s\t%s\t%s\t\t\t\t[rig] %-18s status:%-11s sling:%-7s crew:%s polecats:%s\n' \
        "$rig" "$rig" "$status" "$rig" "$status" "$sling_state" "$crew_count" "$polecats"
    fi

    if [[ "$mode" == "crews" || "$mode" == "all" ]]; then
      while IFS=$'\t' read -r _rig crew_name branch live git_state; do
        [[ -n "$crew_name" ]] || continue
        printf 'crew\t%s\t%s\t%s/%s\t\t\t\t[crew] %-18s session:%-7s branch:%s git:%s\n' \
          "$rig" "$crew_name" "$live" "$git_state" "$rig/$crew_name" "$live" "$branch" "$git_state"
      done < <(list_crews_tsv "$rig")
    fi
  done < <(list_rigs_tsv)
}

build_input_rows() {
  local mode
  mode="$(normalize_picker_mode "${1:-$(current_picker_mode)}")"
  case "$mode" in
    sessions)
      build_tmux_rows
      ;;
    crews|rigs)
      build_gastown_rows "$mode"
      ;;
    all)
      build_tmux_rows
      build_gastown_rows "$mode"
      ;;
  esac
}

handle_tmux_session_selection() {
  local socket="$1" session="$2"
  if [[ -z "$socket" || -z "$session" ]]; then
    exit 0
  fi

  if ! tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
    tmux -L "$socket" new-session -ds "$session"
  fi

  if [[ -n "${TMUX:-}" ]]; then
    if [[ "$socket" == "$CURRENT_SOCKET" ]]; then
      tmux -L "$socket" switch-client -t "$session"
      return
    fi
    tmux detach-client -E "tmux -L $socket attach-session -t $session"
    return
  fi

  tmux -L "$socket" attach-session -t "$session"
}

preview_row() {
  local entry_kind="$1" rig="$2" name="$3" status="$4" socket="$5" session="$6" attached="$7"
  case "$entry_kind" in
    session)
      tmux -L "$socket" capture-pane -pt "$session" 2>/dev/null | tail -n 120
      ;;
    rig)
      if command -v gt >/dev/null 2>&1; then
        gt rig status "$rig" 2>/dev/null
      else
        printf 'Rig: %s\nStatus: %s\n' "$rig" "$status"
      fi
      ;;
    crew)
      if command -v gt >/dev/null 2>&1; then
        gt crew status "$name" --rig "$rig" 2>/dev/null
      else
        printf 'Crew: %s/%s\nStatus: %s\n' "$rig" "$name" "$status"
      fi
      ;;
    *)
      printf 'No preview available for %s\n' "$entry_kind"
      ;;
  esac
}

short_prompt_title() {
  local prompt="$1" one_line
  one_line="$(printf '%s' "$prompt" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | trim_whitespace)"
  one_line="${one_line:0:60}"
  printf 'Prompt: %s\n' "$one_line"
}

create_prompt_bead() {
  local rig="$1" prompt="$2" title description
  title="$(short_prompt_title "$prompt")"
  description="$(cat <<EOF
Ad-hoc prompt captured from tmux-session-pick.

Prompt:
$prompt
EOF
)"
  bd create "$title" --rig "$rig" --type task --priority 2 --description "$description" --silent
}

action_sling_prompt() {
  local rig="$1" rig_status="$2" prompt="$3" bead_id
  if [[ -z "$prompt" ]]; then
    notify_user "Type a prompt, then press Enter on a rig row."
    return 0
  fi

  if [[ "$rig_status" == "docked" ]]; then
    notify_user "Cannot sling to docked rig $rig."
    return 0
  fi

  bead_id="$(create_prompt_bead "$rig" "$prompt")" || {
    notify_user "Unable to create prompt bead for $rig."
    return 1
  }

  gt sling "$bead_id" "$rig" --args "$prompt" --hook-raw-bead >/dev/null 2>&1 || {
    bd close "$bead_id" >/dev/null 2>&1 || true
    notify_user "Unable to sling prompt to $rig."
    return 1
  }

  notify_user "Prompt slung to $rig via $bead_id."
}

handle_action() {
  local action="$1" entry_kind="$2" rig="$3" name="$4"
  case "$action" in
    crew-restart)
      if [[ "$entry_kind" != "crew" ]]; then
        notify_user "Restart is only available on crew rows."
        return 0
      fi
      gt crew restart "$name" --rig "$rig" >/dev/null 2>&1 || notify_user "Crew restart failed for $rig/$name."
      ;;
    crew-stop)
      if [[ "$entry_kind" != "crew" ]]; then
        notify_user "Stop is only available on crew rows."
        return 0
      fi
      gt crew stop "$name" --rig "$rig" >/dev/null 2>&1 || notify_user "Crew stop failed for $rig/$name."
      ;;
    kill-session)
      if [[ "$entry_kind" != "session" ]]; then
        notify_user "Session kill is only available on tmux session rows."
        return 0
      fi
      tmux -L "$5" kill-session -t "$6" >/dev/null 2>&1 || notify_user "Session kill failed for $6."
      ;;
    *)
      notify_user "Unknown action: $action"
      ;;
  esac
}

handle_selection() {
  local entry_kind="$1" rig="$2" name="$3" status="$4" socket="$5" session="$6" attached="$7" query="$8"
  case "$entry_kind" in
    session)
      handle_tmux_session_selection "$socket" "$session"
      ;;
    crew)
      gt crew at "$name" --rig "$rig"
      ;;
    rig)
      action_sling_prompt "$rig" "$status" "$query"
      ;;
    *)
      notify_user "Unsupported entry kind: $entry_kind"
      ;;
  esac
}

main() {
  local input query selected entry_kind rig name status socket session attached
  local preview_location preview_ratio prompt_icon pointer_icon
  local bind_accept bind_exit bind_delete_char bind_scroll_up bind_scroll_down bind_select_up bind_select_down bind_kill_session
  local bind_crew_restart bind_crew_stop bind_mode_sessions bind_mode_crews bind_mode_rigs bind_mode_all bind_cycle_mode
  local additional_fzf_options header result fzf_cmd window_height window_width
  local self_path self_cmd picker_mode

  command -v tmux >/dev/null 2>&1 || { echo "tmux required" >&2; exit 1; }
  case "${1:-}" in
    --list)
      build_input_rows "${2:-}"
      exit 0
      ;;
    --preview)
      shift
      preview_row "$@"
      exit 0
      ;;
    --action)
      shift
      handle_action "$@"
      exit 0
      ;;
    --set-mode)
      set_picker_mode "${2:-sessions}"
      exit 0
      ;;
    --cycle-mode)
      cycle_picker_mode
      exit 0
      ;;
  esac
  if command -v fzf-tmux >/dev/null 2>&1; then
    fzf_cmd="fzf-tmux"
  elif command -v fzf >/dev/null 2>&1; then
    fzf_cmd="fzf"
  else
    echo "fzf or fzf-tmux required" >&2
    exit 1
  fi

  self_path="$(cd -- "$(dirname -- "$0")" && pwd)/$(basename -- "$0")"
  self_cmd="$(printf '%q' "$self_path")"
  picker_mode="$(current_picker_mode)"

  CURRENT_SOCKET="$(socket_from_tmux_env || true)"
  CURRENT_SESSION="$(tmux display-message -p '#S' 2>/dev/null || true)"

  input="$(build_input_rows "$picker_mode")"
  if [[ -z "${input//[[:space:]]/}" ]]; then
    echo "No picker entries found." >&2
    exit 1
  fi

  preview_location="$(tmux_option_or_fallback '@tmux-session-pick-preview-location' 'right')"
  preview_ratio="$(tmux_option_or_fallback '@tmux-session-pick-preview-ratio' '75%')"
  window_height="$(tmux_option_or_fallback '@tmux-session-pick-window-height' '75%')"
  window_width="$(tmux_option_or_fallback '@tmux-session-pick-window-width' '75%')"
  prompt_icon="$(tmux_option_or_fallback '@tmux-session-pick-prompt' ' ')"
  pointer_icon="$(tmux_option_or_fallback '@tmux-session-pick-pointer' '▶')"
  bind_accept="$(tmux_option_or_fallback '@tmux-session-pick-bind-accept' 'enter')"
  bind_exit="$(tmux_option_or_fallback '@tmux-session-pick-bind-abort' 'esc')"
  bind_delete_char="$(tmux_option_or_fallback '@tmux-session-pick-bind-delete-char' 'bspace')"
  bind_scroll_up="$(tmux_option_or_fallback '@tmux-session-pick-bind-scroll-up' 'ctrl-u')"
  bind_scroll_down="$(tmux_option_or_fallback '@tmux-session-pick-bind-scroll-down' 'ctrl-d')"
  bind_select_up="$(tmux_option_or_fallback '@tmux-session-pick-bind-select-up' 'ctrl-n')"
  bind_select_down="$(tmux_option_or_fallback '@tmux-session-pick-bind-select-down' 'ctrl-p')"
  bind_kill_session="$(tmux_option_or_fallback '@tmux-session-pick-bind-kill-session' 'alt-bspace')"
  bind_crew_restart="$(tmux_option_or_fallback '@tmux-session-pick-bind-crew-restart' 'alt-r')"
  bind_crew_stop="$(tmux_option_or_fallback '@tmux-session-pick-bind-crew-stop' 'alt-x')"
  bind_mode_sessions="$(tmux_option_or_fallback '@tmux-session-pick-bind-mode-sessions' 'alt-1')"
  bind_mode_crews="$(tmux_option_or_fallback '@tmux-session-pick-bind-mode-crews' 'alt-2')"
  bind_mode_rigs="$(tmux_option_or_fallback '@tmux-session-pick-bind-mode-rigs' 'alt-3')"
  bind_mode_all="$(tmux_option_or_fallback '@tmux-session-pick-bind-mode-all' 'alt-4')"
  bind_cycle_mode="$(tmux_option_or_fallback '@tmux-session-pick-bind-cycle-mode' 'alt-m')"
  additional_fzf_options="$(tmux_option_or_fallback '@tmux-session-pick-additional-options' '--color pointer:9,spinner:92,marker:46')"
  header="$bind_accept=open/sling  $bind_kill_session=kill-session  $bind_crew_restart=restart-crew  $bind_crew_stop=stop-crew  $bind_cycle_mode=cycle-mode  $bind_mode_sessions=sessions  $bind_mode_crews=crews  $bind_mode_rigs=rigs  $bind_mode_all=all  $bind_select_up=up  $bind_select_down=down  $bind_scroll_up=prev-up  $bind_scroll_down=prev-down  ?=toggle-preview"

  if [[ "$fzf_cmd" == "fzf-tmux" ]]; then
    result="$(
      echo "$input" |
        fzf-tmux $additional_fzf_options -p "${window_width},${window_height}" \
          --bind "$bind_accept:accept" \
          --bind "$bind_exit:abort" \
          --bind "$bind_delete_char:backward-delete-char" \
          --bind "$bind_select_up:up" \
          --bind "$bind_select_down:down" \
          --bind "$bind_scroll_up:preview-half-page-up" \
          --bind "$bind_scroll_down:preview-half-page-down" \
          --bind "$bind_kill_session:execute-silent($self_cmd --action kill-session {1} {2} {3} {4} {5} {6} {7})+reload($self_cmd --list)" \
          --bind "$bind_crew_restart:execute-silent($self_cmd --action crew-restart {1} {2} {3} {4} {5} {6} {7})+reload($self_cmd --list)" \
          --bind "$bind_crew_stop:execute-silent($self_cmd --action crew-stop {1} {2} {3} {4} {5} {6} {7})+reload($self_cmd --list)" \
          --bind "$bind_cycle_mode:execute-silent($self_cmd --cycle-mode)+reload($self_cmd --list)" \
          --bind "$bind_mode_sessions:execute-silent($self_cmd --set-mode sessions)+reload($self_cmd --list sessions)" \
          --bind "$bind_mode_crews:execute-silent($self_cmd --set-mode crews)+reload($self_cmd --list crews)" \
          --bind "$bind_mode_rigs:execute-silent($self_cmd --set-mode rigs)+reload($self_cmd --list rigs)" \
          --bind "$bind_mode_all:execute-silent($self_cmd --set-mode all)+reload($self_cmd --list all)" \
          --bind '?:toggle-preview' \
          --delimiter $'\t' \
          --with-nth=8 \
          --header "$header" \
          --prompt "$prompt_icon" \
          --pointer "$pointer_icon" \
          --layout default \
          --preview "$self_cmd --preview {1} {2} {3} {4} {5} {6} {7}" \
          --preview-window "${preview_location},${preview_ratio},," \
          --print-query \
          --exit-0 \
          --tac
    )" || exit 0
  else
    result="$(
      echo "$input" |
        fzf $additional_fzf_options \
          --bind "$bind_accept:accept" \
          --bind "$bind_exit:abort" \
          --bind "$bind_delete_char:backward-delete-char" \
          --bind "$bind_select_up:up" \
          --bind "$bind_select_down:down" \
          --bind "$bind_scroll_up:preview-half-page-up" \
          --bind "$bind_scroll_down:preview-half-page-down" \
          --bind "$bind_kill_session:execute-silent($self_cmd --action kill-session {1} {2} {3} {4} {5} {6} {7})+reload($self_cmd --list)" \
          --bind "$bind_crew_restart:execute-silent($self_cmd --action crew-restart {1} {2} {3} {4} {5} {6} {7})+reload($self_cmd --list)" \
          --bind "$bind_crew_stop:execute-silent($self_cmd --action crew-stop {1} {2} {3} {4} {5} {6} {7})+reload($self_cmd --list)" \
          --bind "$bind_cycle_mode:execute-silent($self_cmd --cycle-mode)+reload($self_cmd --list)" \
          --bind "$bind_mode_sessions:execute-silent($self_cmd --set-mode sessions)+reload($self_cmd --list sessions)" \
          --bind "$bind_mode_crews:execute-silent($self_cmd --set-mode crews)+reload($self_cmd --list crews)" \
          --bind "$bind_mode_rigs:execute-silent($self_cmd --set-mode rigs)+reload($self_cmd --list rigs)" \
          --bind "$bind_mode_all:execute-silent($self_cmd --set-mode all)+reload($self_cmd --list all)" \
          --bind '?:toggle-preview' \
          --delimiter $'\t' \
          --with-nth=8 \
          --header "$header" \
          --prompt "$prompt_icon" \
          --pointer "$pointer_icon" \
          --layout default \
          --preview "$self_cmd --preview {1} {2} {3} {4} {5} {6} {7}" \
          --preview-window "${preview_location},${preview_ratio},," \
          --print-query \
          --exit-0 \
          --tac
    )" || exit 0
  fi

  query="$(printf '%s\n' "$result" | sed -n '1p' | trim_whitespace)"
  selected="$(printf '%s\n' "$result" | sed -n '2p')"

  if [[ -n "$selected" && "$selected" == *$'\t'* ]]; then
    entry_kind="$(printf '%s' "$selected" | cut -f1)"
    rig="$(printf '%s' "$selected" | cut -f2)"
    name="$(printf '%s' "$selected" | cut -f3)"
    status="$(printf '%s' "$selected" | cut -f4)"
    socket="$(printf '%s' "$selected" | cut -f5)"
    session="$(printf '%s' "$selected" | cut -f6)"
    attached="$(printf '%s' "$selected" | cut -f7)"
    handle_selection "$entry_kind" "$rig" "$name" "$status" "$socket" "$session" "$attached" "$query"
    exit 0
  fi

  if [[ -z "$query" ]]; then
    exit 0
  fi

  # Accept can yield the display text ("[gt] session-name") when using
  # replace-query+print-query. Parse that explicitly before treating as new name.
  if [[ "$query" =~ ^\[([^][]+)\][[:space:]]+(.+)$ ]]; then
    socket="${BASH_REMATCH[1]}"
    session="${BASH_REMATCH[2]}"
    handle_tmux_session_selection "$socket" "$session"
    exit 0
  fi

  # Query-only accept (new session): create in current socket, else default.
  socket="${CURRENT_SOCKET:-default}"
  handle_tmux_session_selection "$socket" "$query"
}

main "$@"
